{
    "name": "luz",
    "displayName": "Luz Language",
    "description": "Luz language support: syntax highlighting, autocompletion, error detection, snippets",
    "version": "1.0.0",
    "publisher": "Elabsurdo984",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "activationEvents": [
        "onLanguage:luz"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [{
            "id": "luz",
            "aliases": ["Luz", "luz"],
            "extensions": [".luz"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "luz",
            "scopeName": "source.luz",
            "path": "./syntaxes/luz.tmLanguage.json"
        }],
        "snippets": [{
            "language": "luz",
            "path": "./snippets/luz.json"
        }],
        "configuration": {
            "title": "Luz",
            "properties": {
                "luz.executablePath": {
                    "type": "string",
                    "default": "luz",
                    "description": "Path to the luz executable"
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.75.0",
        "typescript": "^5.0.0"
    }
}
