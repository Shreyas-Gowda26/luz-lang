{
    "Function": {
        "prefix": "function",
        "body": ["function ${1:name}(${2:params}) {", "\t${3:pass}", "}"],
        "description": "Define a function"
    },
    "If": {
        "prefix": "if",
        "body": ["if ${1:condition} {", "\t${2:pass}", "}"],
        "description": "If statement"
    },
    "If / Else": {
        "prefix": "ife",
        "body": ["if ${1:condition} {", "\t${2:pass}", "} else {", "\t${3:pass}", "}"],
        "description": "If / else statement"
    },
    "If / Elif / Else": {
        "prefix": "ifee",
        "body": [
            "if ${1:condition} {",
            "\t${2:pass}",
            "} elif ${3:condition} {",
            "\t${4:pass}",
            "} else {",
            "\t${5:pass}",
            "}"
        ],
        "description": "If / elif / else statement"
    },
    "While": {
        "prefix": "while",
        "body": ["while ${1:condition} {", "\t${2:pass}", "}"],
        "description": "While loop"
    },
    "For range": {
        "prefix": "for",
        "body": ["for ${1:i} = ${2:1} to ${3:10} {", "\t${4:pass}", "}"],
        "description": "For range loop"
    },
    "For each": {
        "prefix": "fore",
        "body": ["for ${1:item} in ${2:list} {", "\t${3:pass}", "}"],
        "description": "For each loop"
    },
    "Class": {
        "prefix": "class",
        "body": [
            "class ${1:Name} {",
            "\tfunction init(self${2:, params}) {",
            "\t\t${3:pass}",
            "\t}",
            "}"
        ],
        "description": "Class definition"
    },
    "Class with inheritance": {
        "prefix": "classe",
        "body": [
            "class ${1:Name} extends ${2:Parent} {",
            "\tfunction init(self${3:, params}) {",
            "\t\tsuper.init(${4:})",
            "\t\t${5:pass}",
            "\t}",
            "}"
        ],
        "description": "Class with inheritance"
    },
    "Method": {
        "prefix": "method",
        "body": ["function ${1:name}(self${2:, params}) {", "\t${3:pass}", "}"],
        "description": "Class method"
    },
    "Attempt / Rescue": {
        "prefix": "attempt",
        "body": [
            "attempt {",
            "\t${1:pass}",
            "} rescue (${2:e}) {",
            "\twrite(${2:e})",
            "}"
        ],
        "description": "Error handling block"
    },
    "Lambda short": {
        "prefix": "fn",
        "body": ["fn(${1:x}) => ${2:x}"],
        "description": "Lambda short form"
    },
    "Lambda long": {
        "prefix": "fnb",
        "body": ["fn(${1:x}) {", "\treturn ${2:x}", "}"],
        "description": "Lambda long form"
    },
    "Import": {
        "prefix": "import",
        "body": ["import \"${1:module}\""],
        "description": "Import a module"
    },
    "Write": {
        "prefix": "write",
        "body": ["write(${1:value})"],
        "description": "Print to stdout"
    },
    "Format string": {
        "prefix": "fs",
        "body": ["\\$\"${1:text}\""],
        "description": "Format string"
    }
}
